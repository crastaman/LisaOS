# LisaOS / OpenClaw provider credentials — TEMPLATE ONLY
# =====================================================================
# DO NOT put real secrets in this file. This template is committed; real
# values are NOT. Copy the variables you need into the runtime env file:
#
#     ~/.openclaw/.env        (read by the OpenClaw gateway AND by
#                              core.provider_resolver's credential check)
#
# or export them in your shell. Never commit a populated .env.
# =====================================================================

# Qwen on DeepInfra (logical provider: qwen-deepinfra)
# Required for qwen-deepinfra to resolve AVAILABLE; absent => fails closed.
# Get a key from https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=

# Qwen on Alibaba Model Studio (logical provider: qwen-alibaba)
MODEL_STUDIO_API_KEY=

# Z.AI / GLM (optional builder provider)
ZAI_API_KEY=

# Note: the following providers use OAuth or an inline key already present in
# ~/.openclaw/openclaw.json and do NOT need an env var here:
#   deepseek      (inline apiKey in openclaw.json provider block)
#   claude-opus   (OAuth: anthropic:claude-cli)
#   claude-sonnet (OAuth: anthropic:claude-cli)
#   codex, gpt    (OAuth: openai)
