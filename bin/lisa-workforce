#!/usr/bin/env python3
"""lisa-workforce — inspect the LisaOS employee registry and staff work packages.

Usage:
    lisa-workforce employees                     # list employees + preferred model
    lisa-workforce validate                      # validate the employee registry
    lisa-workforce assign <cap[,cap...]> [risk] [mode]
                                                 # staff a work package to an employee
    lisa-workforce gates                         # run pre-sprint anti-regression gates

Exit codes:
    0  ok / assignment resolved
    2  fail-closed (no capable employee / no available model / invalid registry)
    3  gate failure
"""

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from core.provider_resolver import ProviderResolver  # noqa: E402
from core.workforce_resolver import (  # noqa: E402
    EmployeeRegistry,
    WorkforceResolver,
    WorkforceResolutionError,
    WorkPackage,
)
from core.anti_regression import run_pre_sprint_gates, FAIL  # noqa: E402


def _resolver() -> WorkforceResolver:
    return WorkforceResolver(EmployeeRegistry(), ProviderResolver())


def cmd_employees() -> int:
    reg = EmployeeRegistry()
    print("\nLisaOS employees\n")
    print(f"{'employee':30} {'dept':18} {'seniority':11} {'preferred model':16} cost")
    print("-" * 92)
    for e in sorted(reg.employees.values(), key=reg.seniority_rank):
        print(f"{e.id:30} {e.department:18} {e.seniority:11} "
              f"{e.preferred_model:16} {e.cost_class}")
    print()
    return 0


def cmd_validate() -> int:
    reg = EmployeeRegistry()
    problems = reg.validate(ProviderResolver())
    if problems:
        print("EMPLOYEE REGISTRY INVALID:")
        for p in problems:
            print("  -", p)
        return 2
    print(f"employee registry valid: {len(reg.employees)} employees, "
          f"all fields present, all model references known.")
    return 0


def cmd_assign(argv: list[str]) -> int:
    if not argv:
        print("usage: lisa-workforce assign <cap[,cap...]> [risk] [mode]")
        return 2
    caps = [c.strip() for c in argv[0].split(",") if c.strip()]
    risk = argv[1] if len(argv) > 1 else "normal"
    mode = argv[2] if len(argv) > 2 else "balanced"
    wp = WorkPackage(id="cli", description="cli work package",
                     required_capabilities=caps, risk=risk, mode=mode)
    try:
        assignment = _resolver().resolve(wp)
    except WorkforceResolutionError as exc:
        out = exc.evidence.to_dict() if exc.evidence else {}
        out["error"] = str(exc)
        print(json.dumps(out, indent=2))
        return 2
    print(json.dumps(assignment.to_dict(), indent=2))
    return 0


def cmd_gates() -> int:
    report = run_pre_sprint_gates(ProviderResolver())
    for r in report.results:
        print(f"[{r.severity}] {r.name}: {r.detail}")
    return 3 if any(r.severity == FAIL for r in report.results) else 0


def main(argv: list[str]) -> int:
    if not argv:
        print(__doc__)
        return 0
    cmd, rest = argv[0], argv[1:]
    if cmd == "employees":
        return cmd_employees()
    if cmd == "validate":
        return cmd_validate()
    if cmd == "assign":
        return cmd_assign(rest)
    if cmd == "gates":
        return cmd_gates()
    print(f"unknown command: {cmd}")
    print(__doc__)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
